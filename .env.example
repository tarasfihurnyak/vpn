DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vpn
DB_SSLMODE=disable

# Path to the ES256 PEM private key — generate with: make gen-jwt-key
JWT_PRIVATE_KEY_FILE=certs/jwt_private.pem
# JWT_ACCESS_TTL=15m
# JWT_REFRESH_TTL=168h
# JWT_SECURE_COOKIE=true
# JWT_ALLOWED_ORIGINS=http://localhost
